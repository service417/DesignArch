<?xml version="1.0" encoding="utf-8"?>
<!--
  Android blocks cleartext HTTP from API 28 onwards, which is the right default:
  a token or a photograph of someone's work should never cross an unencrypted
  link on a real network.

  The development API runs as plain HTTP on the developer's machine, so cleartext
  is permitted for exactly the loopback addresses that reach it and nothing else.
  10.0.2.2 is the emulator's alias for the host; 10.0.3.2 is Genymotion's.

  Everything else — including any real deployment — stays HTTPS-only, so shipping
  this file to production fails closed rather than silently allowing plaintext.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false"/>
</network-security-config>
