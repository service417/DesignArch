# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=3000

# PostgreSQL (matches docker-compose.yml at the repo root)
DATABASE_URL="postgresql://designarc:designarc_dev_pw@localhost:5432/designarc?schema=public"

# Redis (cache + BullMQ queue)
REDIS_URL="redis://localhost:6379"

# Auth — generate strong random secrets for any non-local environment
JWT_ACCESS_SECRET="change-me-dev-only-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-dev-only-refresh-secret"
JWT_REFRESH_TTL="7d"
BCRYPT_COST=12

# Business configuration (TBD resolutions from the architecture blueprint)
CURRENCY=LKR
DISPLAY_TIMEZONE=Asia/Colombo
MAX_INSPECTION_PHOTOS=10
MAX_PHOTO_BYTES=5242880

# Media storage. The local-disk provider is for development only; production
# swaps StorageModule's binding for the S3 provider and drops these.
MEDIA_LOCAL_ROOT=".local-storage"
# Signs media URLs. Must be stable across restarts or existing links break, and
# must be secret — anyone holding it can mint a link to any stored object.
MEDIA_URL_SECRET="change-me-dev-only-media-url-secret"
MEDIA_URL_TTL_SECONDS=300
# Prefix for generated media links; set to the public origin behind a proxy.
MEDIA_PUBLIC_BASE_URL="/api/v1"
