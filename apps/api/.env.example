# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=3000

# PostgreSQL (matches docker-compose.yml at the repo root)
DATABASE_URL="postgresql://designarc:designarc_dev_pw@localhost:5432/designarc?schema=public"

# Redis (cache + BullMQ queue)
REDIS_URL="redis://localhost:6379"

# Auth — generate strong random secrets for any non-local environment
JWT_ACCESS_SECRET="change-me-dev-only-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-dev-only-refresh-secret"
JWT_REFRESH_TTL="7d"
BCRYPT_COST=12

# Business configuration (TBD resolutions from the architecture blueprint)
CURRENCY=LKR
DISPLAY_TIMEZONE=Asia/Colombo
MAX_INSPECTION_PHOTOS=10
MAX_PHOTO_BYTES=5242880
